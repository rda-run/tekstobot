DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tekstobot

# Select transcription backend: local | cloudflare
# (RPM/systemd: applied on each tekstobot start/restart; no extra script needed)
TRANSCRIBER_BACKEND=local

# WHISPER_URL can be a single URL or a comma-separated list of URLs
WHISPER_URL=http://localhost:8000
# Interval in seconds to health-check the whisper URLs
WHISPER_HEALTH_INTERVAL=30

# Cloudflare Workers AI (used when TRANSCRIBER_BACKEND=cloudflare)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional ISO 639-1 language (e.g. en, es, fr). Empty = auto-detect.
CLOUDFLARE_WHISPER_LANGUAGE=

ADMIN_PHONE=5511999999999
PORT=8080
