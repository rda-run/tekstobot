[Unit]
Description=TekstoBot Service - WhatsApp Audio Transcription Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/lib/tekstobot
ExecStartPre=/usr/libexec/tekstobot/tekstobot-whisper-prestart.sh
ExecStart=/usr/bin/tekstobot
Restart=always
RestartSec=10
EnvironmentFile=-/etc/tekstobot.env
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
